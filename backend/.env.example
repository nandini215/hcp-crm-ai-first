# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hcp_crm

# Groq API (https://console.groq.com/keys)
# gemma2-9b-it has been deprecated by Groq — openai/gpt-oss-120b is the
# current recommended production model with reliable tool-calling support.
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=openai/gpt-oss-120b

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
